def process_batch_host(source_folder, compressed_payload, host_ip, max_till, stop_event, logger):
    """ Executes the specific Laptop -> Host -> Tills flow. """
    results = []
    prefix = '.'.join(host_ip.split('.')[:3])
    ops_source = os.path.join(source_folder, "ETP Store Operations")
    ops_status = "N/A"
    
    # --- 1. Store Operations Logic (If exists locally) ---
    if os.path.exists(ops_source):
        try:
            ssh_ops = connect_ssh(host_ip, HOST_USER, HOST_PASS, TIMEOUT_CONNECT, logger)
            if ssh_ops:
                ops_payload = shutil.make_archive('ops_payload', 'gztar', root_dir=ops_source)
                logger.info(f"[{host_ip}] Uploading ETP Store Operations to Host...")
                upload_and_extract(ssh_ops, ops_payload, '/home/linuxadmin/ETPSuite', 'ETP Store Operations', logger)
                os.remove(ops_payload)
                ssh_ops.close()
                ops_status = "Done"
            else: ops_status = "Connection Failed"
        except Exception as e:
            ops_status = f"Error: {e}"

    logger.info(f"[{host_ip}] Starting StoreFront Host Deployment...")
    
    # --- 2. Laptop to Host Transfer ---
    host_upload_ok = False
    remote_host_tar = f"{HOST_DEST_BASE}/deploy_temp.tar.gz"
    
    try:
        ssh_host = connect_ssh(host_ip, HOST_USER, HOST_PASS, TIMEOUT_CONNECT, logger)
        if ssh_host:
            # Upload the zipped file and extract it so the folder physically exists on the Host Server
            upload_and_extract(ssh_host, compressed_payload, HOST_DEST_BASE, "ETPStoreFrontV5.5", logger)
            host_upload_ok = True
    except Exception as e:
        logger.error(f"[{host_ip}] Host Upload Error: {e}")

    # --- 3. Host to Till Distribution ---
    if host_upload_ok:
        sftp_host = ssh_host.open_sftp() # Open SFTP on the Host to read the zip file
        
        for i in range(1, int(max_till) + 1):
            if stop_event.is_set(): break
            till_ip = f"{prefix}.{TILL_START_OCTET + i}"
            status = "Pending"
            
            try:
                logger.info(f"[{host_ip}] Distributing from Host to Till {till_ip}...")
                ssh_till = connect_ssh(till_ip, TILL_USER, TILL_PASS, 4, logger)
                
                if ssh_till:
                    sftp_till = ssh_till.open_sftp()
                    remote_till_tar = f"{TILL_DEST_BASE}/deploy_temp.tar.gz"
                    
                    # Ensure base folder exists on Till
                    ssh_till.exec_command(f"mkdir -p '{TILL_DEST_BASE}'")
                    
                    # STREAM THE COMPRESSED FILE: Host SFTP -> Laptop RAM -> Till SFTP
                    # (This takes a few seconds because it is one continuous byte stream)
                    with sftp_host.open(remote_host_tar, 'rb') as fr:
                        with sftp_till.open(remote_till_tar, 'wb') as fw:
                            shutil.copyfileobj(fr, fw)
                    
                    # Tell Till to extract the zipped file locally
                    remote_target_dir = f"{TILL_DEST_BASE}/ETPStoreFrontV5.5"
                    ssh_till.exec_command(f"mkdir -p '{remote_target_dir}'")
                    stdin, stdout, stderr = ssh_till.exec_command(f"tar -xzf '{remote_till_tar}' -C '{remote_target_dir}'")
                    stdout.channel.recv_exit_status() # Wait to finish
                    
                    # Delete zip on Till
                    sftp_till.remove(remote_till_tar)
                    sftp_till.close()
                    ssh_till.close()
                    
                    status = "Success"
                    logger.info(f"[{host_ip}] Till {till_ip} Success.")
                else:
                    status = "Failure (Unreachable)"
                    logger.warning(f"[{host_ip}] Till {till_ip} unreachable.")

            except Exception as e:
                status = f"Failure: {str(e)}"
            
            results.append({'HostIP': host_ip, 'TillIP': till_ip, 'Status': status, 'Host_Server_Status': ops_status})
        
        # --- 4. Server Cleanup ---
        # We delete the zip file and the folder from the Host to keep it clean.
        sftp_host.close()
        ssh_host.exec_command(f"rm -f '{remote_host_tar}'")
        ssh_host.exec_command(f"rm -rf '{HOST_DEST_BASE}/ETPStoreFrontV5.5'")
        ssh_host.close()
        
    else:
        # If host fails, all tills fail
        for i in range(1, int(max_till) + 1):
            results.append({'HostIP': host_ip, 'TillIP': f"Till_{i}", 'Status': "Host Upload Failed", 'Host_Server_Status': ops_status})

    return results

