def connect_ssh(host, user, password, timeout, logger):
    try:
        ssh = paramiko.SSHClient()
        ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
        ssh.connect(host, port=22, username=user, password=password, timeout=timeout)
        return ssh
    except Exception as e:
        logger.debug(f"Connection to {host} failed: {e}")
        return None

def upload_and_extract(ssh_client, local_tar_path, remote_base_dir, remote_folder_name, logger):
    """ Uploads 1 compressed file from Laptop to Remote Server, and unzips it. """
    sftp = ssh_client.open_sftp()
    remote_tar_path = f"{remote_base_dir}/deploy_temp.tar.gz"
    remote_target_dir = f"{remote_base_dir}/{remote_folder_name}"

    ssh_client.exec_command(f"mkdir -p '{remote_base_dir}'")
    
    # Upload the file
    sftp.put(local_tar_path, remote_tar_path)

    # Extract it
    ssh_client.exec_command(f"mkdir -p '{remote_target_dir}'")
    stdin, stdout, stderr = ssh_client.exec_command(f"tar -xzf '{remote_tar_path}' -C '{remote_target_dir}'")
    exit_status = stdout.channel.recv_exit_status()
    
    # If this is being called by the Batch Host step, we DO NOT delete the tar file yet, 
    # because the Tills need to copy it. We let the cleanup step handle it later.
    # However, if it's Ops or Manual, we can delete it immediately.
    if "manual_payload" in local_tar_path or "ops_payload" in local_tar_path:
        sftp.remove(remote_tar_path)
        
    sftp.close()

    if exit_status != 0:
        error_msg = stderr.read().decode().strip()
        raise Exception(f"Linux Extraction failed: {error_msg}")

