    def setup_logging(self):
        self.log_filename = f'deployment_{datetime.now().strftime("%Y%m%d_%H%M%S")}.log'
        file_handler = logging.FileHandler(self.log_filename)
        formatter = logging.Formatter('%(asctime)s - %(levelname)s - %(message)s')
        file_handler.setFormatter(formatter)

        self.logger = logging.getLogger(__name__)
        self.logger.setLevel(logging.INFO)
        self.logger.addHandler(file_handler)

        class TextHandler(logging.Handler):
            def __init__(self, text_widget):
                logging.Handler.__init__(self)
                self.text_widget = text_widget
            def emit(self, record):
                msg = self.format(record)
                try: self.text_widget.after(0, lambda: self.text_widget.insert(tk.END, msg + '\n') or self.text_widget.see(tk.END))
                except: pass

        gui_handler = TextHandler(self.log_text)
        gui_handler.setFormatter(formatter)
        self.logger.addHandler(gui_handler)

    def browse_source(self):
        folder = filedialog.askdirectory(initialdir=self.source_folder.get())
        if folder: self.source_folder.set(folder)

    def browse_config(self):
        file = filedialog.askopenfilename(filetypes=[("Excel files", "*.xlsx *.xls")])
        if file: self.config_file.set(file)

    # ==========================================
    #             BATCH DEPLOYMENT
    # ==========================================
    def start_batch_deployment(self):
        source = self.source_folder.get()
        config = self.config_file.get()

        if not os.path.exists(source): return messagebox.showerror("Error", "Source folder not found")
        try:
            df = pd.read_excel(config)
            if 'HostIP' not in df.columns: return messagebox.showerror("Error", "Excel must have 'HostIP' column")
        except Exception as e: return messagebox.showerror("Error", f"Read Excel failed: {e}")

        self.is_deploying = True
        self.stop_event.clear()
        self.start_btn.config(state=tk.DISABLED)
        self.manual_btn.config(state=tk.DISABLED)
        self.stop_btn.config(state=tk.NORMAL)
        
        self.logger.info("Compressing source folder locally. Please wait...")
        Thread(target=self.prepare_and_start_threads, args=(source, df)).start()

    def prepare_and_start_threads(self, source, df):
        try:
            # Compress laptop source folder ONCE
            self.compressed_payload = shutil.make_archive('deploy_payload', 'gztar', root_dir=source)
            self.logger.info(f"Compression complete: {self.compressed_payload}")
        except Exception as e:
            self.logger.error(f"Failed to compress folder: {e}")
            self.deployment_finished()
            return

        self.results_data = []
        self.current_log_file = f'deployment_status_{datetime.now().strftime("%Y%m%d_%H%M%S")}.xlsx'
        
        # Trim spaces from IPs while parsing
        tasks = [{'host': str(row['HostIP']).strip(), 'max_till': row.get('MaxTill', 0)} for _, row in df.iterrows()]
        self.total_hosts = len(tasks)
        self.completed_count = 0
        
        with ui_lock:
            self.progress['maximum'] = self.total_hosts
            self.progress['value'] = 0
            self.progress_label.config(text=f"0/{self.total_hosts}")

        self.executor = ThreadPoolExecutor(max_workers=3)
        for task in tasks:
            self.executor.submit(self.process_host_wrapper, source, task['host'], task['max_till'])

    def process_host_wrapper(self, source_folder, host_ip, max_till):
        if self.stop_event.is_set(): return
        try:
            results = process_batch_host(source_folder, self.compressed_payload, host_ip, max_till, self.stop_event, self.logger)
            with file_lock:
                self.results_data.extend(results)
                pd.DataFrame(self.results_data).to_excel(self.current_log_file, index=False)
        except Exception as e:
            self.logger.error(f"Critical error in thread for {host_ip}: {e}")
        finally:
            with ui_lock:
                self.completed_count += 1
                self.root.after(0, self.update_batch_progress)

    def update_batch_progress(self):
        self.progress['value'] = self.completed_count
        self.progress_label.config(text=f"{self.completed_count}/{self.total_hosts}")
        if self.completed_count >= self.total_hosts: self.deployment_finished()

    def deployment_finished(self):
        self.is_deploying = False
        self.start_btn.config(state=tk.NORMAL)
        self.manual_btn.config(state=tk.NORMAL)
        self.stop_btn.config(state=tk.DISABLED)
        if self.compressed_payload and os.path.exists(self.compressed_payload):
            try: os.remove(self.compressed_payload)
            except: pass
        if not self.stop_event.is_set(): messagebox.showinfo("Done", f"Deployment Completed.\nLog: {self.current_log_file}")

    def stop_deployment(self):
        self.stop_event.set()
        self.status_label.config(text="Stopping... waiting for active transfers to abort.")
        if self.executor: self.executor.shutdown(wait=False)

    # ==========================================
    #             MANUAL DEPLOYMENT
    # ==========================================
    def start_manual_deployment(self):
        host_ip = self.manual_host_ip.get().strip()
        tills_str = self.manual_tills.get().strip()
        source = self.source_folder.get()

        if not host_ip or not tills_str: return messagebox.showerror("Error", "Enter Host IP and Tills")
        try: till_nums = [int(x.strip()) for x in tills_str.split(',') if x.strip().isdigit()]
        except: return messagebox.showerror("Error", "Invalid Till Format. Use: 1, 3, 4")

        self.logger.info(f"--- MANUAL DEPLOY: {host_ip} Tills: {till_nums} ---")
        self.manual_btn.config(state=tk.DISABLED)
        Thread(target=self.run_manual_logic, args=(source, host_ip, till_nums)).start()

    def run_manual_logic(self, source, host_ip, till_nums):
        try:
            # Compress locally
            temp_payload = shutil.make_archive('manual_payload', 'gztar', root_dir=source)
            prefix = '.'.join(host_ip.split('.')[:3])
            
            for num in till_nums:
                till_ip = f"{prefix}.{111 + num}"
                self.logger.info(f"Manual: Connecting to {till_ip} directly...")
                ssh_client = connect_ssh(till_ip, TILL_USER, TILL_PASS, TIMEOUT_CONNECT, self.logger)
                if ssh_client:
                    # Direct Laptop -> Till upload and extract
                    upload_and_extract(ssh_client, temp_payload, TILL_DEST_BASE, "ETPStoreFrontV5.5", self.logger)
                    ssh_client.close()
                    self.logger.info(f"Manual: Direct Upload to {till_ip} COMPLETED.")
                else:
                    self.logger.error(f"Manual: Could not connect to {till_ip}")
            os.remove(temp_payload)
        except Exception as e: self.logger.error(f"Manual Error: {e}")
        finally:
            self.manual_btn.config(state=tk.NORMAL)
            self.logger.info("--- MANUAL DEPLOYMENT END ---")

