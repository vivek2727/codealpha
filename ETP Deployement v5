# ==============================================================================
#  NETWORK UTILITIES
# ==============================================================================

def connect_ssh(host, user, password, timeout, logger):
    """
    Connect via SSH with an enlarged transport window so large file transfers
    don't stall waiting for acknowledgements.
    Window size 2 GB and deferred re-key avoid mid-transfer pauses.
    """
    try:
        sock = socket.create_connection((host, 22), timeout=timeout)
        transport = paramiko.Transport(sock)
        transport.window_size           = 2_147_483_647   # 2 GB window
        transport.packetizer.REKEY_BYTES   = 2 ** 40      # defer re-key
        transport.packetizer.REKEY_PACKETS = 2 ** 40
        transport.connect(username=user, password=password)
        ssh = paramiko.SSHClient()
        ssh._transport = transport
        return ssh
    except Exception as e:
        logger.debug(f"SSH to {host} failed: {e}")
        return None


def check_sshpass(ssh_client):
    """Return True if sshpass is installed on the remote machine."""
    _, stdout, _ = ssh_client.exec_command("which sshpass 2>/dev/null || echo ''")
    return bool(stdout.read().decode().strip())


# ==============================================================================
#  COMPRESSION
# ==============================================================================

def fast_compress(source_dir, output_path):
    """
    Create a .tar.gz archive using gzip level 1 (fastest).
    shutil.make_archive uses level 9 by default — level 1 is ~3-4x faster
    for a modest increase in file size (acceptable on LAN).
    """
    with tarfile.open(output_path, 'w:gz', compresslevel=1) as tar:
        tar.add(source_dir, arcname='.')
    return output_path


# ==============================================================================
#  UPLOAD AND EXTRACT  (Laptop → Host OR Laptop → Till directly)
# ==============================================================================

def upload_and_extract(ssh_client, local_tar_path, remote_base_dir,
                       remote_folder_name, logger, keep_tar=False):
    """
    Upload one compressed archive from the laptop to a remote machine and
    extract it.  chmod -R 777 is applied automatically so no manual fix-up
    is ever needed.

    keep_tar=True  → leave the .tar.gz on the remote (Batch Host step: tills
                      will copy it)
    keep_tar=False → remove the .tar.gz after extraction (Ops / Manual step)
    """
    sftp = ssh_client.open_sftp()
    remote_tar    = f"{remote_base_dir}/deploy_temp.tar.gz"
    remote_target = f"{remote_base_dir}/{remote_folder_name}"

    ssh_client.exec_command(f"mkdir -p '{remote_base_dir}'")

    # Upload with a large internal buffer
    with open(local_tar_path, 'rb') as local_f:
        sftp.putfo(local_f, remote_tar)

    # Extract + permissions + optional cleanup — one round-trip
    cleanup = "" if keep_tar else f" && rm -f '{remote_tar}'"
    cmd = (
        f"mkdir -p '{remote_target}' && "
        f"tar -xzf '{remote_tar}' -C '{remote_target}' && "
        f"chmod -R 777 '{remote_base_dir}'"
        f"{cleanup}"
    )
    _, stdout, stderr = ssh_client.exec_command(cmd)
    exit_status = stdout.channel.recv_exit_status()
    sftp.close()

    if exit_status != 0:
        raise Exception(f"Extraction failed: {stderr.read().decode().strip()}")


# ==============================================================================
#  TILL DISTRIBUTION  (Host → Till, two strategies)
# ==============================================================================

def _deploy_via_sshpass(ssh_host, remote_host_tar, till_ip, logger):
    """
    Ask the Host to SCP the file directly to the Till (pure LAN speed).
    Requires sshpass to be installed on the Host.
    """
    remote_till_tar = f"{TILL_DEST_BASE}/deploy_temp.tar.gz"
    cmd = (
        f"sshpass -p '{TILL_PASS}' scp "
        f"-o StrictHostKeyChecking=no -o ConnectTimeout=10 "
        f"'{remote_host_tar}' {TILL_USER}@{till_ip}:'{remote_till_tar}'"
    )
    _, stdout, stderr = ssh_host.exec_command(cmd, timeout=300)
    rc = stdout.channel.recv_exit_status()
    if rc != 0:
        raise Exception(f"Host-SCP failed (rc={rc}): {stderr.read().decode().strip()}")
    return remote_till_tar


def _deploy_via_relay(sftp_host, till_ip, logger):
    """
    Fallback: stream the file through the laptop using a 2 MB buffer.
    Still slower than sshpass but far faster than the 32 KB default.
    """
    remote_host_tar  = f"{HOST_DEST_BASE}/deploy_temp.tar.gz"
    remote_till_tar  = f"{TILL_DEST_BASE}/deploy_temp.tar.gz"

    ssh_till = connect_ssh(till_ip, TILL_USER, TILL_PASS, TIMEOUT_CONNECT, logger)
    if not ssh_till:
        return None, None

    sftp_till = ssh_till.open_sftp()
    ssh_till.exec_command(f"mkdir -p '{TILL_DEST_BASE}'")

    with sftp_host.open(remote_host_tar, 'rb', bufsize=SFTP_BUFFER) as fr:
        with sftp_till.open(remote_till_tar, 'wb', bufsize=SFTP_BUFFER) as fw:
            shutil.copyfileobj(fr, fw, length=SFTP_BUFFER)

    sftp_till.close()
    return ssh_till, remote_till_tar


def deploy_single_till(ssh_host, sftp_host, host_has_sshpass,
                       remote_host_tar, host_ip, till_ip,
                       stop_event, logger):
    """
    Deploy to one Till.  Returns (till_ip, status_string).
    Called from a thread pool so each till runs in parallel.
    """
    if stop_event.is_set():
        return till_ip, "Stopped"

    remote_till_tar  = f"{TILL_DEST_BASE}/deploy_temp.tar.gz"
    remote_target    = f"{TILL_DEST_BASE}/ETPStoreFrontV5.5"
    t_start = datetime.now()

    try:
        if host_has_sshpass:
            # ── Strategy A: Host pushes directly to Till ──────────────────
            logger.info(f"[{host_ip}] → {till_ip}  (host-side SCP via sshpass)")
            remote_till_tar = _deploy_via_sshpass(ssh_host, remote_host_tar, till_ip, logger)

            ssh_till = connect_ssh(till_ip, TILL_USER, TILL_PASS, TIMEOUT_CONNECT, logger)
            if not ssh_till:
                return till_ip, "Failure (Unreachable after SCP)"
        else:
            # ── Strategy B: Stream through laptop with 2 MB buffer ────────
            logger.info(f"[{host_ip}] → {till_ip}  (laptop relay, 2 MB buffer)")
            ssh_till = connect_ssh(till_ip, TILL_USER, TILL_PASS, TIMEOUT_CONNECT, logger)
            if not ssh_till:
                return till_ip, "Failure (Unreachable)"

            sftp_till = ssh_till.open_sftp()
            ssh_till.exec_command(f"mkdir -p '{TILL_DEST_BASE}'")
            with sftp_host.open(remote_host_tar, 'rb', bufsize=SFTP_BUFFER) as fr:
                with sftp_till.open(remote_till_tar, 'wb', bufsize=SFTP_BUFFER) as fw:
                    shutil.copyfileobj(fr, fw, length=SFTP_BUFFER)
            sftp_till.close()

        # ── Extract + chmod + cleanup (single SSH round-trip) ────────────
        cmd = (
            f"mkdir -p '{remote_target}' && "
            f"tar -xzf '{remote_till_tar}' -C '{remote_target}' && "
            f"chmod -R 777 '{TILL_DEST_BASE}' && "
            f"rm -f '{remote_till_tar}'"
        )
        _, stdout, stderr = ssh_till.exec_command(cmd)
        rc = stdout.channel.recv_exit_status()
        ssh_till.close()

        if rc != 0:
            err = stderr.read().decode().strip()
            return till_ip, f"Failure (Extract: {err})"

        elapsed = (datetime.now() - t_start).seconds
        logger.info(f"[{host_ip}] Till {till_ip} SUCCESS  ({elapsed}s)")
        return till_ip, "Success"

    except Exception as e:
        logger.error(f"[{host_ip}] Till {till_ip} error: {e}")
        return till_ip, f"Failure: {str(e)}"


# ==============================================================================
#  CORE BATCH HOST LOGIC
# ==============================================================================

def process_batch_host(source_folder, compressed_payload, host_ip, max_till,
                       stop_event, logger):
    """
    Full deployment flow for one Host + all its Tills.

    Step 1  Store Operations upload to Host  (if the sub-folder exists)
    Step 2  StoreFront archive upload to Host
    Step 3  Parallel distribution to all Tills  (sshpass or buffered relay)
    Step 4  Host cleanup
    """
    results   = []
    prefix    = '.'.join(host_ip.split('.')[:3])
    ops_source = os.path.join(source_folder, "ETP Store Operations")
    ops_status = "N/A"

    # ── 1. Store Operations ──────────────────────────────────────────────────
    if os.path.exists(ops_source):
        try:
            ssh_ops = connect_ssh(host_ip, HOST_USER, HOST_PASS, TIMEOUT_CONNECT, logger)
            if ssh_ops:
                ops_tar = fast_compress(ops_source, 'ops_payload.tar.gz')
                logger.info(f"[{host_ip}] Uploading ETP Store Operations...")
                upload_and_extract(ssh_ops, ops_tar, '/home/linuxadmin/ETPSuite',
                                   'ETP Store Operations', logger, keep_tar=False)
                os.remove(ops_tar)
                ssh_ops.close()
                ops_status = "Done"
            else:
                ops_status = "Connection Failed"
        except Exception as e:
            ops_status = f"Error: {e}"
            logger.error(f"[{host_ip}] Ops error: {e}")

    # ── 2. Upload StoreFront archive to Host ─────────────────────────────────
    logger.info(f"[{host_ip}] Uploading StoreFront archive to Host...")
    t0 = datetime.now()

    ssh_host = connect_ssh(host_ip, HOST_USER, HOST_PASS, TIMEOUT_CONNECT, logger)
    if not ssh_host:
        logger.error(f"[{host_ip}] Cannot connect to Host — skipping all tills.")
        for i in range(1, int(max_till) + 1):
            results.append({'HostIP': host_ip,
                            'TillIP': f"{prefix}.{TILL_START_OCTET + i}",
                            'Status': "Host Unreachable",
                            'Host_Server_Status': ops_status})
        return results

    remote_host_tar = f"{HOST_DEST_BASE}/deploy_temp.tar.gz"
    try:
        upload_and_extract(ssh_host, compressed_payload, HOST_DEST_BASE,
                           "ETPStoreFrontV5.5", logger, keep_tar=True)
        upload_secs = (datetime.now() - t0).seconds
        logger.info(f"[{host_ip}] Host upload done in {upload_secs}s")
    except Exception as e:
        logger.error(f"[{host_ip}] Host upload failed: {e}")
        ssh_host.close()
        for i in range(1, int(max_till) + 1):
            results.append({'HostIP': host_ip,
                            'TillIP': f"{prefix}.{TILL_START_OCTET + i}",
                            'Status': f"Host Upload Failed: {e}",
                            'Host_Server_Status': ops_status})
        return results

    # ── 3. Parallel Till distribution ────────────────────────────────────────
    host_has_sshpass = check_sshpass(ssh_host)
    method = "host-side SCP (sshpass)" if host_has_sshpass else "laptop relay (2 MB buffer)"
    logger.info(f"[{host_ip}] Distributing to {max_till} tills — method: {method}")

    sftp_host = ssh_host.open_sftp()

    till_ips = [
        f"{prefix}.{TILL_START_OCTET + i}"
        for i in range(1, int(max_till) + 1)
    ]

    workers = min(len(till_ips), TILL_PARALLEL_WORKERS)
    with ThreadPoolExecutor(max_workers=workers) as pool:
        futures = {
            pool.submit(
                deploy_single_till,
                ssh_host, sftp_host, host_has_sshpass,
                remote_host_tar, host_ip, t_ip,
                stop_event, logger
            ): t_ip
            for t_ip in till_ips
            if not stop_event.is_set()
        }
        for future in as_completed(futures):
            t_ip, status = future.result()
            results.append({
                'HostIP':             host_ip,
                'TillIP':             t_ip,
                'Status':             status,
                'Host_Server_Status': ops_status
            })

    # ── 4. Host cleanup ───────────────────────────────────────────────────────
    sftp_host.close()
    ssh_host.exec_command(f"rm -f '{remote_host_tar}'")
    ssh_host.exec_command(f"rm -rf '{HOST_DEST_BASE}/ETPStoreFrontV5.5'")
    ssh_host.close()

    return results


