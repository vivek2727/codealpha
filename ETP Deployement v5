    def setup_logging(self):
        self.log_filename = f'deployment_{datetime.now().strftime("%Y%m%d_%H%M%S")}.log'
        fh = logging.FileHandler(self.log_filename)
        fmt = logging.Formatter('%(asctime)s - %(levelname)s - %(message)s')
        fh.setFormatter(fmt)

        self.logger = logging.getLogger(__name__)
        self.logger.setLevel(logging.INFO)
        self.logger.addHandler(fh)

        class _TextHandler(logging.Handler):
            def __init__(self, widget):
                super().__init__()
                self.widget = widget
            def emit(self, record):
                msg = self.format(record)
                try:
                    self.widget.after(0,
                        lambda m=msg: (self.widget.insert(tk.END, m + '\n'),
                                       self.widget.see(tk.END)))
                except Exception:
                    pass

        gh = _TextHandler(self.log_text)
        gh.setFormatter(fmt)
        self.logger.addHandler(gh)

    def browse_source(self):
        d = filedialog.askdirectory(initialdir=self.source_folder.get())
        if d: self.source_folder.set(d)

    def browse_config(self):
        f = filedialog.askopenfilename(filetypes=[("Excel files", "*.xlsx *.xls")])
        if f: self.config_file.set(f)

    # ── Batch Deployment ──────────────────────────────────────────────────────

    def start_batch_deployment(self):
        source = self.source_folder.get()
        config = self.config_file.get()

        if not os.path.exists(source):
            return messagebox.showerror("Error", "Source folder not found")
        try:
            df = pd.read_excel(config)
            if 'HostIP' not in df.columns:
                return messagebox.showerror("Error", "Excel must have 'HostIP' column")
        except Exception as e:
            return messagebox.showerror("Error", f"Read Excel failed: {e}")

        self.is_deploying = True
        self.stop_event.clear()
        self.start_btn.config(state=tk.DISABLED)
        self.manual_btn.config(state=tk.DISABLED)
        self.stop_btn.config(state=tk.NORMAL)
        self.status_label.config(text="Compressing source folder (gzip level 1)...")

        Thread(target=self.prepare_and_start_threads, args=(source, df)).start()

    def prepare_and_start_threads(self, source, df):
        t0 = datetime.now()
        try:
            payload_path = 'deploy_payload.tar.gz'
            fast_compress(source, payload_path)
            self.compressed_payload = os.path.abspath(payload_path)
            secs = (datetime.now() - t0).seconds
            size_mb = os.path.getsize(self.compressed_payload) / 1_048_576
            self.logger.info(
                f"Compression done in {secs}s — {size_mb:.1f} MB  "
                f"(gzip level 1, ~3-4x faster than default)"
            )
        except Exception as e:
            self.logger.error(f"Compression failed: {e}")
            self.deployment_finished()
            return

        self.results_data   = []
        self.current_log_file = f'deployment_status_{datetime.now().strftime("%Y%m%d_%H%M%S")}.xlsx'
        tasks = [{'host': str(r['HostIP']).strip(),
                  'max_till': r.get('MaxTill', 0)}
                 for _, r in df.iterrows()]

        self.total_hosts     = len(tasks)
        self.completed_count = 0

        with ui_lock:
            self.progress['maximum'] = self.total_hosts
            self.progress['value']   = 0
            self.progress_label.config(text=f"0/{self.total_hosts}")

        self.executor = ThreadPoolExecutor(max_workers=3)
        for t in tasks:
            self.executor.submit(
                self.process_host_wrapper,
                source, t['host'], t['max_till']
            )

    def process_host_wrapper(self, source_folder, host_ip, max_till):
        if self.stop_event.is_set():
            return
        try:
            results = process_batch_host(
                source_folder, self.compressed_payload,
                host_ip, max_till,
                self.stop_event, self.logger
            )
            with file_lock:
                self.results_data.extend(results)
                pd.DataFrame(self.results_data).to_excel(self.current_log_file, index=False)
        except Exception as e:
            self.logger.error(f"Critical thread error for {host_ip}: {e}")
        finally:
            with ui_lock:
                self.completed_count += 1
                self.root.after(0, self.update_batch_progress)

    def update_batch_progress(self):
        self.progress['value'] = self.completed_count
        self.progress_label.config(text=f"{self.completed_count}/{self.total_hosts}")
        pct = int(self.completed_count / max(self.total_hosts, 1) * 100)
        self.status_label.config(text=f"Deploying... {pct}%")
        if self.completed_count >= self.total_hosts:
            self.deployment_finished()

    def deployment_finished(self):
        self.is_deploying = False
        self.start_btn.config(state=tk.NORMAL)
        self.manual_btn.config(state=tk.NORMAL)
        self.stop_btn.config(state=tk.DISABLED)
        self.status_label.config(text="Deployment complete.")
        if self.compressed_payload and os.path.exists(self.compressed_payload):
            try:
                os.remove(self.compressed_payload)
            except Exception:
                pass
        if not self.stop_event.is_set():
            messagebox.showinfo(
                "Done",
                f"Deployment completed.\nResults saved to:\n{self.current_log_file}"
            )

    def stop_deployment(self):
        self.stop_event.set()
        self.status_label.config(text="Stopping… waiting for active transfers to finish.")
        if self.executor:
            self.executor.shutdown(wait=False)

    # ── Manual Deployment ─────────────────────────────────────────────────────

    def start_manual_deployment(self):
        host_ip   = self.manual_host_ip.get().strip()
        tills_str = self.manual_tills.get().strip()
        source    = self.source_folder.get()

        if not host_ip or not tills_str:
            return messagebox.showerror("Error", "Enter Host IP and Till numbers")
        try:
            till_nums = [int(x.strip()) for x in tills_str.split(',') if x.strip().isdigit()]
        except Exception:
            return messagebox.showerror("Error", "Invalid till format. Use: 1, 3, 4")

        self.logger.info(f"--- MANUAL DEPLOY: {host_ip} Tills: {till_nums} ---")
        self.manual_btn.config(state=tk.DISABLED)
        Thread(target=self.run_manual_logic, args=(source, host_ip, till_nums)).start()

    def run_manual_logic(self, source, host_ip, till_nums):
        prefix = '.'.join(host_ip.split('.')[:3])
        try:
            temp_payload = 'manual_payload.tar.gz'
            self.logger.info("Compressing for manual deploy (level 1)...")
            fast_compress(source, temp_payload)
            self.logger.info(f"Compression done — {os.path.getsize(temp_payload)/1_048_576:.1f} MB")

            for num in till_nums:
                till_ip = f"{prefix}.{TILL_START_OCTET + num}"
                self.logger.info(f"Manual → {till_ip}")
                ssh = connect_ssh(till_ip, TILL_USER, TILL_PASS, TIMEOUT_CONNECT, self.logger)
                if ssh:
                    upload_and_extract(ssh, temp_payload, TILL_DEST_BASE,
                                       "ETPStoreFrontV5.5", self.logger, keep_tar=False)
                    ssh.close()
                    self.logger.info(f"Manual: {till_ip} SUCCESS (chmod 777 applied)")
                else:
                    self.logger.error(f"Manual: {till_ip} unreachable")

            os.remove(temp_payload)
        except Exception as e:
            self.logger.error(f"Manual error: {e}")
        finally:
            self.manual_btn.config(state=tk.NORMAL)
            self.logger.info("--- MANUAL DEPLOYMENT END ---")


